generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "mysql"
}

model Branch {
  id        String     @id @default(cuid())
  code      String     @unique
  label     String
  createdAt DateTime   @default(now())
  employees Employee[]

  @@index([code])
  @@map("branch")
}

model Position {
  id            String   @id @default(cuid())
  name          String   @unique
  contractMonths Int     @default(6)
  createdAt     DateTime @default(now())

  @@map("position")
}

model Contract {
  id             String   @id @default(cuid())
  employeeId     String
  posisi         String
  traineeSejak   DateTime @db.Date
  traineeSelesai DateTime @db.Date
  contractNumber String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  contractPath   String?
  employee       Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade, map: "Contract_employeeId_fkey")

  @@index([employeeId], map: "Contract_employeeId_fkey")
  @@index([traineeSelesai])
  @@map("contract")
}

model Employee {
  id           String      @id @default(cuid())
  ba           String
  baCabang     String
  region       String?
  cabang       String
  namaLengkap  String
  status       String      @default("AKTIF")
  nik          String?
  noJamsostek  String?
  noKtp        String      @unique
  tglLahir     DateTime?   @db.Date
  namaIbu      String
  noHp         String?
  formConsent  String?
  gender       String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  image        String?
  kkPath       String?
  ktpPath      String?
  branch       Branch?     @relation(fields: [cabang], references: [code], onDelete: Restrict)
  contracts    Contract[]

  @@index([status])
  @@index([cabang])
  @@index([status, cabang])
  @@index([namaLengkap])
  @@map("employee")
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique(map: "User_username_key")
  password  String
  role      String   @default("VIEWER")
  createdAt DateTime @default(now())

  @@map("user")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  userName  String
  action    String
  entity    String
  entityId  String
  details   String   @db.Text
  createdAt DateTime @default(now())

  @@index([action])
  @@index([createdAt])
  @@index([entityId])
  @@map("auditlog")
}
