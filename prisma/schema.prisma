generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "mysql"
}

model Contract {
  id             String   @id @default(cuid())
  employeeId     String
  posisi         String
  traineeSejak   DateTime @db.Date
  traineeSelesai DateTime @db.Date
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  contractPath   String?
  employee       Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade, map: "Contract_employeeId_fkey")

  @@index([employeeId], map: "Contract_employeeId_fkey")
  @@map("contract") // Tetap menggunakan nama tabel kecil di MySQL
}

model Employee {
  id          String     @id @default(cuid())
  ba          String
  baCabang    String
  region      String
  cabang      String
  namaLengkap String
  status      String     @default("AKTIF")
  nik         String?
  noJamsostek String?
  noKtp       String
  tglLahir    String
  namaIbu     String
  noHp        String
  formConsent String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  image       String?
  kkPath      String?
  ktpPath     String?
  contracts   Contract[]
  
  @@map("employee")
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique(map: "User_username_key")
  password  String
  role      String   // "ADMIN" atau "VIEWER"
  createdAt DateTime @default(now()) // Tambahan untuk memperbaiki Error "Unknown argument createdAt"
  
  @@map("user")
}

// --- MODEL UNTUK AUDIT TRAIL ---
model AuditLog {
  id        String   @id @default(cuid())
  userId    String   // ID User yang melakukan aksi
  userName  String   // Nama User untuk tracking cepat
  action    String   // CREATE, UPDATE, DELETE
  entity    String   // Employee, Contract, dll
  entityId  String   // ID data yang dimodifikasi
  details   String   @db.Text // Detail perubahan dalam format JSON string
  createdAt DateTime @default(now())

  @@map("auditlog")
}