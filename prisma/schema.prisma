generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "mysql"
}

model Contract {
  id             String   @id @default(cuid())
  employeeId     String
  posisi         String
  traineeSejak   DateTime @db.Date
  traineeSelesai DateTime @db.Date
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  contractPath   String?
  employee       Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade, map: "Contract_employeeId_fkey")

  @@index([employeeId], map: "Contract_employeeId_fkey")
  @@index([traineeSelesai])              // Query kontrak hampir habis
  @@map("contract")
}

model Employee {
  id          String     @id @default(cuid())
  ba          String
  baCabang    String
  region      String
  cabang      String
  namaLengkap String
  status      String     @default("AKTIF")
  nik         String?
  noJamsostek String?
  noKtp       String
  tglLahir    String
  namaIbu     String
  noHp        String
  formConsent String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  image       String?
  kkPath      String?
  ktpPath     String?
  contracts   Contract[]

  @@index([status])                      // Filter by status
  @@index([cabang])                      // Filter by cabang
  @@index([status, cabang])              // Dashboard groupBy query
  @@index([namaLengkap])                 // Search by name
  @@map("employee")
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique(map: "User_username_key")
  password  String
  role      String
  createdAt DateTime @default(now())

  @@map("user")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  userName  String
  action    String
  entity    String
  entityId  String
  details   String   @db.Text
  createdAt DateTime @default(now())

  @@index([action])                      // Filter by action type
  @@index([createdAt])                   // Sort/range query
  @@index([entityId])                    // Per-entity audit trail
  @@map("auditlog")
}
